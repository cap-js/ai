	{
		"_version": "3.2",
		"identification": {
			"id": "CARDAPP_BOOKS",
			"entityType": "businessapp",
			"title": "Books"
		},
		"payload": {
			"visualizations": {
				"CARD_BOOKS": {
					"vizType": "sap.card",
					"vizConfig": {
						"sap.app": {
							"id": "sap.capire.card.books",
							"type": "card",
							"i18n": "./dynamic_dest/intelligent-cap-app-app-srv/i18n/i18n.properties",
							"title": "{{CARD_BOOKS_TITLE}}",
							"subtitle": "{{CARD_BOOKS_SUBTITLE}}"
						},
						"sap.card": {
							"type": "List",
							"configuration": {
								"parameters": {
									"top": {
										"value": 4,
										"type": "integer"
									},
									"maxItems": {
										"value": 4
									}
								}
							},
							"header": {
								"data": {
									"request": {
										"url": "/dynamic_dest/intelligent-cap-app-app-srv/odata/v4/catalog/Books",
										"parameters": {
											"$count": true
										}
									},
									"path": "/"
								},
								"actions": [
									{
										"type": "Navigation",
										"parameters": {
											"ibnTarget": {
												"semanticObject": "Recommendations",
												"action": "Manage"
											}
										}
									}
								],
								"title": "{{CARD_BOOKS_TITLE}}",
								"subTitle": "{{CARD_BOOKS_SUBTITLE}}",
								"status": {
									"text": "{= format.text(${i18n>CARD.COUNT_X_OF_Y}, [${paginator>/skip} + ${parameters>/visibleItems}, ${@odata.count}])}"
								}
							},
							"content": {
								"data": {
									"request": {
										"url": "/dynamic_dest/intelligent-cap-app-app-srv/odata/v4/catalog/Books?$select=title,ID"
									},
									"path": "/value"
								},
								"maxItems": "{parameters>/maxItems/value}",
								"item": {
									"title": "{title}",
									"description": "{ID}",
									"actions": [
										{
											"type": "Navigation",
											"parameters": {
												"ibnTarget": {
													"semanticObject": "Recommendations",
													"action": "Manage"
												},
												"ibnParams": {
													"ID": "{ID}"
												}
											}
										}
									]
								}
							},
							"footer": {
								"paginator": {
									"totalCount": "{/@odata.count}",
									"pageSize": "{parameters>/top/value}"
								}
							}
						}
					}
				}
			}
		}
	},
