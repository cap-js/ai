{
  "name": "ai-bookshop",
  "version": "2.0.41",
  "description": "A VT/STAR application.",
  "keywords": [
    "ui5",
    "openui5",
    "sapui5"
  ],
  "main": "webapp/index.html",
  "scripts": {
    "build:cf": "ui5 build preload --clean-dest --config ui5-deploy.yaml --include-task=generateCachebusterInfo",
    "build": "ui5 build preload --clean-dest",
    "start": "ui5 serve"
  },
  "devDependencies": {
    "@sap/ux-specification": "latest",
    "@ui5/cli": "^4.0.0",
    "@ui5/fs": "^4.0.0",
    "@ui5/logger": "^4.0.0",
    "ui5-task-zipper": "^3.4.1"
  },
  "ui5": {
    "dependencies": [
      "ui5-task-zipper"
    ]
  }
}
